@model IEnumerable<ComicStoreASP.Models.Comics>

<h1>Upload CSV File</h1>

<form asp-action="Index" asp-controller="Home" method="post" enctype="multipart/form-data">
    <input type="file" name="csvFile" class="form-control" required />
    <button type="submit" class="btn btn-primary mt-2">Upload</button>
</form>

@if (Model != null && Model.Any())
{
    <table id="comicsTable" class="table table-striped table-bordered mt-4">
        <thead>
            <tr>
                <th>Actions</th>
                <th>Title</th>
                <th>Name</th>
                <th>Role</th>
                <th>Other Names</th>
                <th>BLRecord ID</th>
                <th>Content Type</th>
                <th>Country</th>
                <th>Publisher</th>
                <th>Date</th>
                <th>Edition</th>
                <th>Topics</th>
                <th>Genre</th>
                <th>Languages</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <button class="btn btn-sm btn-primary"
                                onclick="addToCart(@user.BLRecordID)">
                            Add
                        </button>
                    </td>
                    <td>@user.Title</td>
                    <td>@user.Name</td>
                    <td>@user.Role</td>
                    <td>@user.OtherNames</td>
                    <td>@user.BLRecordID</td>
                    <td>@user.ContentType</td>
                    <td>@user.CountryOfPublication</td>
                    <td>@user.Publisher</td>
                    <td>@user.DateOfPublication</td>
                    <td>@user.Edition</td>
                    <td>@user.Topics</td>
                    <td>@user.Genre</td>
                    <td>@user.Languages</td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#comicsTable').DataTable({
                pageLength: 25,
                scrollX: true,
                columnDefs: [
                    { orderable: false, targets: 0 } // Actions column
                ]
            });
        });

        const cart = [];
        function addToCart(id) {
            if (!cart.includes(id)) {
                cart.push(id);
                alert("Added to cart");
            }
            console.log(cart);
        }
    </script>
}


