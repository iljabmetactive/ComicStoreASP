@model IEnumerable<ComicStoreASP.Models.ComicGroupedViewModel>

<head>
    <h1>Comic Store</h1>
</head>

@* <h1>Upload CSV File</h1> *@

@* <form asp-action="Index" asp-controller="Home" method="post" enctype="multipart/form-data">
    <input type="file" name="csvFile" class="form-control" required />
    <button type="submit" class="btn btn-primary mt-2">Upload</button>
</form> *@


@if (User.Identity.IsAuthenticated)
{
    <h4>Advanced Search</h4>
    <form id="advancedSearchForm" class="mb-4">
        @Html.AntiForgeryToken()
        <div class="row">
            <input type="text" id="titleSearch" name="Title" class="form-control" placeholder="Title" />
            <input type="text" id="authorSearch" name="AuthorName" class="form-control" placeholder="Author" />
            <div class="col-md-2"><input type="text" name="YearOfPublication" class="form-control" placeholder="Publication Year" /></div>
            <input type="text" id="genreSearch" name="Genre" class="form-control" placeholder="Genre" />
            <div class="col-md-2"><input type="text" name="Edition" class="form-control" placeholder="Edition" /></div>
            <div class="col-md-2 mt-2"><input type="text" name="Language" class="form-control" placeholder="Language" /></div>
        </div>
        <button type="submit" class="btn btn-success mt-3">Search</button>
    </form>
}
<div id="searchResults"></div>


<div>
    <div class="mb-3">

        <h5>Top Searches</h5>
        <table class="table table-sm table-bordered" id="analyticsTable">
            <thead>
                <tr>
                    <th>Search Term</th>
                    <th>Count</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
    <div class="mb-3">
        <label for="genreFilter" class="form-label">Filter by Genre</label>
        <select id="genreFilter" class="form-select">
            <option value="show all">Show All</option>

            @foreach (var genre in Model
                        .Select(c => c.Genre)
                        .Where(g => !string.IsNullOrWhiteSpace(g))
                        .Distinct()
                        .OrderBy(g => g))
                        {
                            <option value="@genre">@genre</option>
                        }
        </select>
    </div>

        <div style="margin-bottom:15px;">
            <label>Sort by:</label>

            <select id="sortColumn">
                <option value="1">Title</option>
                <option value="2">Names</option>
                <option value="3">Roles</option>
                <option value="7">Year of Publication</option>
                <option value="8">Publisher</option>
                <option value="11">Genre</option>
            </select>

            <button id="toggleSortOrder">Sort</button>
	    </div>

        <table id="comicsTable" class="table table-striped table-bordered mt-4">
            <thead>
                <tr>
                    <th>Actions</th>
                    <th>Title</th>
                    <th>Names</th>
                    <th>Roles</th>
                    <th>BLRecord ID</th>
                    <th>Content Type</th>
                    <th>Country</th>
                    <th>Year</th>
                    <th>Publisher</th>
                    <th>Edition</th>
                    <th>Topics</th>
                    <th data-column="genre">Genre</th>
                    <th>Languages</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var comic in Model)
                {
                    <tr>
                        <td>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <button class="btn btn-success btn-sm"
                                        onclick="saveComic(@comic.ComicId)">
                                    Save
                                </button>
                            } 

                            @if (User.IsInRole("Staff"))
                            {
                                <button class="btn btn-warning btn-sm"
                                        onclick="flagComic(@comic.ComicId)">
                                    Flag
                                </button>
                            }
                            @if (User.Identity.IsAuthenticated)
                            {
                                <button class="btn btn-primary btn-sm"
                                    onclick="openReviewBox(@comic.ComicId)">
                                    Review
                                </button>
                            }
                            @if (User.Identity.IsAuthenticated)
                            {
                                <button class="btn btn-info btn-sm"
                                    onclick="loadReviews(@comic.ComicId)">
                                    View Review
							    </button>
                            }
                    </td>

                        <td>@comic.Title</td>
                        <td>@string.Join(", ", comic.Names ?? new List<string>())</td>
                        <td>@string.Join(", ", comic.Roles ?? new List<string>())</td>
                        <td>@string.Join(", ", comic.BLRecordIDs ?? new List<int>())</td>
                        <td>@string.Join(", ", comic.ContentType != null ? new List<string> { comic.ContentType } : new List<string>())</td>
                        <td>@comic.CountryOfPublication</td>
                        <td>@string.Join(", ", comic.PublicationYears ?? new List<string>())</td>
                        <td>@comic.Publisher</td>
                        <td>@string.Join(", ", comic.Editions ?? new List<string>())</td>
                        <td>@string.Join(", ", comic.Topics ?? new List<string>())</td>
                        <td>@comic.Genre</td>
                        <td>@string.Join(", ", comic.Languages ?? new List<string>())</td>

                    </tr>
                }
            </tbody>
        </table>
        <div id="reviewSection" style="margin-top:20px; display:none;">
            <h4>Add Review</h4>

            <input type="hidden" id="reviewComicId" />

            <label>Rating (1–5)</label>
            <input type="number" id="reviewRating" min="1" max="5" class="form-control" />

            <label>Comment</label>
            <textarea id="reviewComment" class="form-control"></textarea>

            <button onclick="submitReview()" class="btn btn-success mt-2">
                Submit Review
            </button>
        </div>

        <div id="reviewsList" class="mt-4"></div>
</div>

@section Scripts {
    <script>
        let table;
        let currentDirection = 'asc';
        const isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();
        const isStaff = @User.IsInRole("Staff").ToString().ToLower();

        $(document).ready(function () {
            if (!$('#comicsTable').length) return;

            table = $('#comicsTable').DataTable({
                pageLength: 25,
                scrollX: true,
                columnDefs: [
                    { orderable: false, targets: 0 }
                ]
            });

            $('#toggleSortOrder').on('click', function () {
                const selectedColumn = $('#sortColumn').val();
                currentDirection = currentDirection === 'asc' ? 'desc' : 'asc';

                table.order([selectedColumn, currentDirection]).draw();
                $(this).text(currentDirection === 'asc' ? 'Ascending' : 'Descending');
            });

            loadSearchAnalytics();

            const genreColumnIndex = $('#comicsTable th[data-column="genre"]').index();

            $('#genreFilter').on('change', function () {
                const selectedGenre = this.value;

                if (selectedGenre === 'show all') {
                    table.column(genreColumnIndex).search('').draw();
                } else {
                    table.column(genreColumnIndex)
                        .search('^' + selectedGenre + '$', true, false)
                        .draw();
                }
            });

            let searchTimeout;
            table.on('search.dt', function () {
                clearTimeout(searchTimeout);

                searchTimeout = setTimeout(() => {
                    const searchTerm = table.search().trim();

                    if (searchTerm.length > 1) {
                        sendSearchAnalytics(searchTerm);
                        loadSearchAnalytics();
                    }
                }, 500);
            });
        });

        function sendSearchAnalytics(term) {
            fetch('/Home/LogSearch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(term)
            });
        }

        function loadSearchAnalytics() {
            fetch('/Home/GetCurrentSearchAnalytics')
                .then(res => res.json())
                .then(data => {
                    const tbody = $('#analyticsTable tbody');
                    tbody.empty();

                    data.forEach(item => {
                        tbody.append(`
                            <tr>
                                <td>${item.term}</td>
                                <td>${item.count}</td>
                            </tr>
                        `);
                    });
                });
        }

        function saveComic(comicId) {
            fetch('/Home/SaveComic', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                body: JSON.stringify({ ComicId: comicId })
            })
            .then(res => res.ok ? alert("Added to cart") : alert("Failed to add comic"));
        }

        function flagComic(comicId) {
            fetch('/Home/FlagComic', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                body: JSON.stringify({ ComicId: comicId, Reason: "Flagged by staff" })
            })
            .then(res => res.ok ? alert("Comic flagged") : alert("Failed to flag comic"));
        }

        document.addEventListener("DOMContentLoaded", function () {

            setUpAutoComplete("titleSearch", "title");
            setUpAutoComplete("authorSearch", "author");
            setUpAutoComplete("genreSearch", "genre");

            const searchForm = document.getElementById("advancedSearchForm");
            if (!searchForm) return;

            searchForm.addEventListener("submit", async function (e) {
                e.preventDefault();

                const formData = new FormData(this);
                const data = Object.fromEntries(formData.entries());
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                try {
                    const response = await fetch('/Home/AdvancedSearch', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify(data)
                    });

                    const results = await response.json();

                    if (results.length === 0) {
                        table.clear().draw();
                        return;
                    }

                    table.clear();

                    results.forEach(c => {
                        const comicId = c.comicId || c.ComicId;

                        let actions = '';
                        if (comicId) {
                            if (isAuthenticated) {
                                actions += `<button class="btn btn-success btn-sm" onclick="saveComic(${comicId})">Save</button>`;
                            }
                            if (isStaff) {
                                actions += `<button class="btn btn-warning btn-sm" onclick="flagComic(${comicId})">Flag</button>`;
                            }
                        }

                        table.row.add([
                            actions,
                            c.title || c.Title || '',
                            (c.names || c.Names || []).join(', '),
                            (c.roles || c.Roles || []).join(', '),
                            (c.blRecordIDs || c.BLRecordIDs || []).join(', '),
                            c.contentType || c.ContentType || '',
                            c.countryOfPublication || c.CountryOfPublication || '',
                            (c.publicationYears || c.PublicationYears || []).join(', '),
                            c.publisher || c.Publisher || '',
                            (c.editions || c.Editions || []).join(', '),
                            (c.topics || c.Topics || []).join(', '),
                            c.genre || c.Genre || '',
                            (c.languages || c.Languages || []).join(', ')
                        ]);
                    });

                    table.draw();

                } catch (err) {
                    console.error("Search failed:", err);
                }
            });
        });


        function setUpAutoComplete(inputId, field) {
            const input = document.getElementById(inputId);
            if (!input) return;

            const suggestionBox = document.createElement('div');
            suggestionBox.classList.add('autocomplete-suggestions');
            input.parentNode.appendChild(suggestionBox);

            let timeout;

            input.addEventListener('input', function () {
                clearTimeout(timeout);

                const query = this.value.trim();

                if (query.length < 2) {
                    suggestionBox.innerHTML = '';
                    return;
                }

                timeout = setTimeout(() => {
                    fetch(`/api/suggestions?field=${field}&Search=${encodeURIComponent(query)}`)
                        .then(res => res.json())
                        .then(data => {
                            suggestionBox.innerHTML = "";

                            data.forEach(item => {
                                const div = document.createElement('div');
                                div.classList.add('autocomplete-suggestion');
                                div.textContent = item;

                                div.addEventListener('click', () => {
                                    input.value = item;
                                    suggestionBox.innerHTML = '';
                                });

                                suggestionBox.appendChild(div);
                            });
                        });
                }, 300);
            });
        }


        function openReviewBox(comicId) {
            document.getElementById("reviewComicId").value = comicId;
            document.getElementById("reviewSection").style.display = "block";
        }

        function submitReview() {
            const comicId = document.getElementById("reviewComicId").value;
            const rating = document.getElementById("reviewRating").value;
            const comment = document.getElementById("reviewComment").value;

            fetch(`/api/reviews/${comicId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    rating: parseInt(rating),
                    comment: comment
                })
            })
            .then(res => {
                if (res.ok) {
                    alert("Review added!");
                    loadReviews(comicId);
                } else {
                    alert("Review failed");
                }
            });
        }

        function loadReviews(comicId) {
            fetch(`/api/reviews/${comicId}`)
                .then(res => {
                    if (!res.ok) throw new Error("Server error");
                    return res.json();
                })
                .then(data => {
                    const reviewsList = document.getElementById("reviewsList");
                    reviewsList.innerHTML = "<h4>Reviews</h4>";

                    data.forEach(review => {
                        reviewsList.innerHTML += `
                            <div class="card mb-2">
                                <div class="card-body">
                                    <strong>Rating:</strong> ${review.rating}/5 <br/>
                                    <p>${review.comment}</p>
                                    <small>${new Date(review.createdAt).toLocaleString()}</small>
                                </div>
                            </div>
                        `;
                    });
                })
                .catch(err => console.error("Review load failed:", err));
        }
    </script>

}



