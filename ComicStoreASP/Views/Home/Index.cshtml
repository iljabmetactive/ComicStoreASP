<h4>Advanced Search</h4>

<form asp-action="AdvancedSearch" asp-controller="Home" method="post" class="mb-4">

    <div class="row">
        <div class="col-md-3">
            <input type="text" name="Title" class="form-control" placeholder="Title" />
        </div>

        <div class="col-md-3">
            <input type="text" name="AuthorName" class="form-control" placeholder="Author" />
        </div>

        <div class="col-md-2">
            <input type="text" name="YearOfPublication" class="form-control" placeholder="Publication Year" />
        </div>

        <div class="col-md-2">
            <input type="text" name="Genre" class="form-control" placeholder="Genre" />
        </div>

        <div class="col-md-2">
            <input type="text" name="Edition" class="form-control" placeholder="Edition" />
        </div>

        <div class="col-md-2 mt-2">
            <input type="text" name="Language" class="form-control" placeholder="Language" />
        </div>
    </div>

    <button type="submit" class="btn btn-success mt-3">
        Search
    </button>

</form>

