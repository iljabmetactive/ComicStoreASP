@* @model IEnumerable<ComicStoreASP.Models.Comics> *@
@model IEnumerable<ComicStoreASP.Views.Models.ComicGroupedViewModel>

<h1>Upload CSV File</h1>

<form asp-action="Index" asp-controller="Home" method="post" enctype="multipart/form-data">
    <input type="file" name="csvFile" class="form-control" required />
    <button type="submit" class="btn btn-primary mt-2">Upload</button>
</form>
<div>
    <div class="mb-3">
        <h5>Top Searches</h5>
        <table class="table table-sm table-bordered" id="analyticsTable">
            <thead>
                <tr>
                    <th>Search Term</th>
                    <th>Count</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    @if (Model != null && Model.Any())
    {
        <table id="comicsTable" class="table table-striped table-bordered mt-4">
            <thead>
                <tr>
                    <th>Actions</th>
                    <th>Title</th>
                    <th>Name</th>
                    <th>Role</th>
                    <th>Other Names</th>
                    <th>BLRecord ID</th>
                    <th>Content Type</th>
                    <th>Country</th>
                    <th>Publisher</th>
                    <th>Date</th>
                    <th>Edition</th>
                    <th>Topics</th>
                    <th>Genre</th>
                    <th>Languages</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    onclick="addToCart(@user.BLRecordID)">
                                Add
                            </button>
                        </td>
                        <td>@user.Title</td>
                        <td>@string.Join(", ", user.Names)</td>
                        <td>@string.Join(", ", user.Roles)</td>
                        <td>@string.Join(", ", user.OtherNames)</td>
                        <td>
                            @if (user.BLRecordIDs != null)
                            {
                                foreach (var year in user.BLRecordIDs)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>@user.ContentType</td>
                        <td>
                            @if (user.PublicationYears != null)
                            {
                                foreach (var year in user.PublicationYears)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>@user.Publisher</td>
                        <td>
                            @if (user.PublicationYears != null)
                            {
                                foreach (var year in user.PublicationYears)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>
                            @if (user.Editions != null)
                            {
                                foreach (var year in user.Editions)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>
                            @if (user.Topics != null)
                            {
                                foreach (var year in user.Topics)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>@user.Genre</td>
                        <td>
                            @if (user.Languages != null)
                            {
                                foreach (var year in user.Languages)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @section Scripts {
        <script>
                $(document).ready(function () {
                const table = $('#comicsTable').DataTable({
                    pageLength: 25,
                    scrollX: true,
                    columnDefs: [
                        { orderable: false, targets: 0 }
                    ]
                });
                loadSearchAnalytics();

                // Capture search input
                let searchTimeout;
                table.on('search.dt', function () {
                    clearTimeout(searchTimeout);

                    searchTimeout = setTimeout(() => {
                        const searchTerm = table.search().trim();

                        if (searchTerm.length > 1) {
                            sendSearchAnalytics(searchTerm);
                            loadSearchAnalytics();
                        }
                    }, 500);
            });

            });

            const cart = [];
            function addToCart(id) {
                if (!cart.includes(id)) {
                    cart.push(id);
                    alert("Added to cart");
                }
                console.log(cart);
            }

            function sendSearchAnalytics(term) {
                fetch('/Home/LogSearch', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(term)
                });
            }

            function loadSearchAnalytics() {
                fetch('/Home/GetSearchAnalytics')
                    .then(res => res.json())
                    .then(data => {
                        const tbody = $('#analyticsTable tbody');
                        tbody.empty();

                        data.forEach(item => {
                            const parts = item.split(' — ');
                            const term = parts[0];
                            const count = parts[1];

                            tbody.append(`
                                <tr>
                                    <td>${term}</td>
                                    <td>${count}</td>
                                </tr>
                            `);
                        });
                    });
            }

        </script>
    }
</div>

