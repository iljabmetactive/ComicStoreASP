@model IEnumerable<ComicStoreASP.Models.ComicGroupedViewModel>

<h1>Upload CSV File</h1>

<form asp-action="Index" asp-controller="Home" method="post" enctype="multipart/form-data">
    <input type="file" name="csvFile" class="form-control" required />
    <button type="submit" class="btn btn-primary mt-2">Upload</button>

    <button type="submit" class="btn btn-success mt-3">
        Search
    </button>
</form>
<h4>Advanced Search</h4>

<form asp-action="AdvancedSearch" asp-controller="Home" method="post" class="mb-4">

    <div class="row">
        <div class="col-md-3">
            <input type="text" name="Title" class="form-control" placeholder="Title" />
        </div>

        <div class="col-md-3">
            <input type="text" name="AuthorName" class="form-control" placeholder="Author" />
        </div>

        <div class="col-md-2">
            <input type="text" name="YearOfPublication" class="form-control" placeholder="Publication Year" />
        </div>

        <div class="col-md-2">
            <input type="text" name="Genre" class="form-control" placeholder="Genre" />
        </div>

        <div class="col-md-2">
            <input type="text" name="Edition" class="form-control" placeholder="Edition" />
        </div>

        <div class="col-md-2 mt-2">
            <input type="text" name="Language" class="form-control" placeholder="Language" />
        </div>
    </div>

    <button type="submit" class="btn btn-success mt-3">
        Search
    </button>

</form>

<div>
    <div class="mb-3">

        <h5>Top Searches</h5>
        <table class="table table-sm table-bordered" id="analyticsTable">
            <thead>
                <tr>
                    <th>Search Term</th>
                    <th>Count</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
    <div class="mb-3">
        <label for="genreFilter" class="form-label">Filter by Genre</label>
        <select id="genreFilter" class="form-select">
            <option value="show all">Show All</option>

            @foreach (var genre in Model
                        .Select(c => c.Genre)
                        .Where(g => !string.IsNullOrWhiteSpace(g))
                        .Distinct()
                        .OrderBy(g => g))
            {
                <option value="@genre">@genre</option>
            }
        </select>
    </div>

    @if (Model != null && Model.Any())
    {
        <div style="margin-bottom:15px;">
            <label>Sort by:</label>

            <select id="sortColumn">
                <option value="1">Title</option>
                <option value="2">Names</option>
                <option value="3">Roles</option>
                <option value="7">Year of Publication</option>
                <option value="8">Publisher</option>
                <option value="11">Genre</option>
            </select>

            <button id="toggleSortOrder">Sort</button>
        </div>



        <table id="comicsTable" class="table table-striped table-bordered mt-4">
            <thead>
                <tr>
                    <th>Actions</th>
                    <th>Title</th>
                    <th>Names</th>
                    <th>Roles</th>
                    <th>BLRecord ID</th>
                    <th>Content Type</th>
                    <th>Country</th>
                    <th>Year of Publication</th>
                    <th>Publisher</th>
                    <th>Edition</th>
                    <th>Topics</th>
                    <th data-column="genre">Genre</th>
                    <th>Languages</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    onclick="addToCart(@user.BLRecordID)">
                                Add
                            </button>
                        </td>
                        <td>@user.Title</td>
                        <td>@string.Join(", ", user.Names)</td>
                        <td>@string.Join(", ", user.Roles)</td>
                        <td>@string.Join(", ", user.OtherNames)</td>
                        <td>
                            @if (user.BLRecordIDs != null)
                            {
                                foreach (var year in user.BLRecordIDs)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>@user.ContentType</td>
                        <td>
                            @if (user.PublicationYears != null)
                            {
                                foreach (var year in user.PublicationYears)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>@user.Publisher</td>
                        <td>
                            @if (user.Editions != null)
                            {
                                foreach (var year in user.Editions)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>
                            @if (user.Topics != null)
                            {
                                foreach (var year in user.Topics)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                        <td>@user.Genre</td>
                        <td>
                            @if (user.Languages != null)
                            {
                                foreach (var year in user.Languages)
                                {
                                    <div>@year</div>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @section Scripts {
        <script>
                let table;
				let currentDirection = 'asc';

                $(document).ready(function () {
					if (!$('#comicsTable').length){return; }

                table = $('#comicsTable').DataTable({
                    pageLength: 25,
                    scrollX: true,
                    columnDefs: [
                        { orderable: false, targets: 0 }
                    ]
                });
                //sorting button
                $('#toggleSortOrder').on('click', function () {
                    const selectedColumn = $('#sortColumn').val();

                    currentDirection = currentDirection === 'asc' ? 'desc' : 'asc';
                    table.order([selectedColumn, currentDirection]).draw();
                    $(this).text(currentDirection === 'asc' ? 'Ascending' : 'Descending');
                });
                loadSearchAnalytics();
                //genre filter
                const genreColumnIndex = $('#comicsTable th[data-column="genre"]').index();

                $('#genreFilter').on('change', function () {
                    const selectedGenre = this.value;

                    if (selectedGenre === 'show all') {
                        table.column(genreColumnIndex).search('').draw();
                    } else {
                        table.column(genreColumnIndex)
                             .search('^' + selectedGenre + '$', true, false)
                             .draw();
                }
                });
                // Capture search input
                let searchTimeout;
                table.on('search.dt', function () {
                    clearTimeout(searchTimeout);

                    searchTimeout = setTimeout(() => {
                        const searchTerm = table.search().trim();

                        if (searchTerm.length > 1) {
                            sendSearchAnalytics(searchTerm);
                            loadSearchAnalytics();
                        }
                    }, 500);

                });
        });
            const cart = [];
            function addToCart(id) {
                if (!cart.includes(id)) {
                    cart.push(id);
                    alert("Added to cart");
                }
                console.log(cart);
            }

            function sendSearchAnalytics(term) {
                fetch('/Home/LogSearch', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(term)
                });
            }

            function loadSearchAnalytics() {
                fetch('/Home/GetSearchAnalytics')
                    .then(res => res.json())
                    .then(data => {
                        const tbody = $('#analyticsTable tbody');
                        tbody.empty();

                        data.forEach(item => {
                            const parts = item.split(' — ');
                            const term = parts[0];
                            const count = parts[1];

                            tbody.append(`
                                <tr>
                                    <td>${term}</td>
                                    <td>${count}</td>
                                </tr>
                            `);
                        });
                    });
                //             $(document).ready(function () {
                // const table = $('#comicsTable').DataTable({
                //     pageLength: 25,
                //     scrollX: true,
                //     columnDefs: [
                //         { orderable: false, targets: 0 }
                //     ]
                // });

            }

        </script>
    }
</div>

